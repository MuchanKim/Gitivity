// Gitivity Secrets Configuration
// Copy this file to Secrets.xcconfig and fill in your values.
// Do NOT commit Secrets.xcconfig to git.

GITHUB_CLIENT_ID = YOUR_GITHUB_CLIENT_ID
// NOTE: Use $() to escape // in URLs (xcconfig treats // as comment)
// Example: https:/$()/your-proxy.workers.dev
OAUTH_PROXY_URL = YOUR_OAUTH_PROXY_URL
